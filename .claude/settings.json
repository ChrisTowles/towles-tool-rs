{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-slot-pkill.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-typecheck.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-synthetic-input.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-time-based-ids.sh\""
          }
        ]
      }
    ],
    "WorktreeCreate": [
      { "hooks": [{ "type": "command", "command": "tt slot hook-create" }] }
    ],
    "WorktreeRemove": [
      { "hooks": [{ "type": "command", "command": "tt slot hook-remove" }] }
    ]
  }
}
