{
  "$schema": "https://schema.tauri.app/capabilities/2",
  "identifier": "default",
  "description": "Core permissions for app windows (event listen/emit, core APIs) plus spawning/closing the standalone Settings window",
  "windows": ["main", "settings"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "opener:default"
  ]
}
