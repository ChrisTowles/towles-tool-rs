{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Towles Tool",
  "version": "0.1.0",
  "identifier": "dev.towles.tool",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../apps/client/dist",
    "beforeDevCommand": "npm run dev --workspace @towles-tool/client",
    "beforeBuildCommand": "npm run build --workspace @towles-tool/client"
  },
  "app": {
    "windows": [
      {
        "title": "Towles Tool",
        "width": 1100,
        "height": 750
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
