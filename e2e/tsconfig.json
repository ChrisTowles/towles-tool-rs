{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": [
      "node",
      "@wdio/globals/types",
      "@wdio/tauri-service",
      "@wdio/mocha-framework",
      "expect-webdriverio"
    ],
    "skipLibCheck": true,

    /* scripts/task-port.mjs is imported from here; its JSDoc carries the types
       (there is no .d.mts sidecar to drift). checkJs stays off — that file is
       typechecked by its own scripts/tsconfig.json. */
    "allowJs": true,
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true
  },
  "include": ["**/*.ts"]
}
