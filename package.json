{
  "name": "towles-tool-rs",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/client"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node scripts/dev-port.mjs",
    "run": "node scripts/run.mjs",
    "dev:drive": "node scripts/dev-drive.mjs",
    "drive": "node scripts/drive.mjs",
    "build": "tauri build",
    "tauri": "tauri",
    "client:dev": "npm run dev --workspace @towles-tool/client",
    "e2e": "node scripts/e2e.mjs",
    "e2e:run": "node scripts/e2e.mjs --no-build",
    "test:scripts": "node --test \"scripts/*.test.mjs\""
  },
  "comment:overrides": "@wdio/tauri-service@1.2.0 exact-pins @wdio/native-utils@2.4.0 but imports installMockSyncOverride, only added in 2.5.0 — a broken pin. Force 2.5.0 until upstream fixes it.",
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "tsx": "^4.23.0"
  }
}
