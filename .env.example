# Rendered into .env by `tt slot new` / `tt slot env` — ${tt:...} tokens are
# per-checkout substitutions (see CLAUDE.md "Worktree slots"). Copying by hand
# instead? Replace each token with a concrete value.

# Vite dev-server port for this checkout (scripts/slot-port.mjs reads .env; a
# manual .env.local pin overrides it, shell env overrides both).
TT_DEV_PORT=${tt:port 1420-1619}

# Embedded WebDriver server port for dev:drive / e2e (scripts read this via
# resolveWebdriverPort; unset falls back to TT_DEV_PORT + 3000).
TT_E2E_WEBDRIVER_PORT=${tt:port 4420-4619}

# Setup step `tt slot new` runs in a fresh slot (spawned directly, no shell —
# point it at a task runner for anything beyond one command).
# --prefer-offline: package-lock.json already pins exact versions, so a cache
# hit (very likely — every prior slot's install populated the same npm
# cache) needs no network revalidation. A real cut in round-trips behind a
# slow or TLS-inspecting proxy; an uncached package still falls back to the
# network.
TT_SLOT_SETUP=npm install --prefer-offline
