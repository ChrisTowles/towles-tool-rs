# Rendered into .env by `ttr slot new` / `ttr slot env` — ${tt:...} tokens are
# per-slot substitutions (see CLAUDE.md "Worktree slots"). Copying by hand
# instead? Replace each token with a concrete value.

# Vite dev-server port for this slot (scripts/slot-port.mjs reads .env; a
# manual .env.local pin overrides it, shell env overrides both).
TT_DEV_PORT=${tt:port 1420-1619}
