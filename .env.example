# Rendered into .env by `tt task new` / `tt task env` — ${tt:...} tokens are
# per-checkout substitutions (see CLAUDE.md "Worktree tasks"). Copying by hand
# instead? Replace each token with a concrete value.

# Vite dev-server port for this checkout (scripts/task-port.mjs reads .env; a
# manual .env.local pin overrides it, shell env overrides both).
TT_DEV_PORT=${tt:port 1420-1619}

# Embedded WebDriver server port for dev:drive / e2e (scripts read this via
# resolveWebdriverPort; unset falls back to TT_DEV_PORT + 3000).
TT_E2E_WEBDRIVER_PORT=${tt:port 4420-4619}

# Setup step `tt task new` runs in a fresh task (spawned directly, no shell —
# point it at a task runner for anything beyond one command).
# --prefer-offline: package-lock.json already pins exact versions, so a cache
# hit (very likely — every prior task's install populated the same npm
# cache) needs no network revalidation. A real cut in round-trips behind a
# slow or TLS-inspecting proxy; an uncached package still falls back to the
# network.
TT_TASK_SETUP=npm install --prefer-offline

# Teardown step `tt task rm`/`clean` runs against a task's own worktree right
# before it removes it (spawned directly, no shell). Nothing runs by default —
# unlike setup there's no lockfile-style fallback to detect. Point it at
# whatever a task's setup started that removal doesn't already know to stop —
# e.g. a docker compose stack that isn't named after this task, so the
# built-in anchored container/volume sweep can't find it on its own.
#TT_TASK_TEARDOWN=docker compose down --volumes
